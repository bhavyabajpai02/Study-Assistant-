# Aether Study Assistant Backend Configuration Example
# Copy this file to '.env' and fill in your credentials

# The port the Express backend server listens on (default is 5000)
PORT=5000

# Your Google Gemini API Key for AI note processing (from Google AI Studio)
GEMINI_API_KEY=

# Secret string used to sign JWT session tokens (choose a secure random phrase)
JWT_SECRET=super_secure_random_phrase_here

# Connection string for your MongoDB Database (falls back to local connection if empty)
# Example: mongodb+srv://username:password@cluster.mongodb.net/databaseName
MONGODB_URI=
